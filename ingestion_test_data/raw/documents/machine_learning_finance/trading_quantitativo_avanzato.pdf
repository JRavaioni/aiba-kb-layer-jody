### A.2 Esempio di Pipeline di Trading Completa

```python
import pandas as pd
import numpy as np
from datetime import datetime, timedelta

class QuantitativeTradingPipeline:
    def __init__(self, symbols, start_date, end_date):
        self.symbols = symbols
        self.start_date = start_date
        self.end_date = end_date
        self.data = {}
        self.models = {}
        self.positions = {}

    def load_market_data(self):
        """Load historical market data"""
        for symbol in self.symbols:
            # In real implementation, load from data provider
            self.data[symbol] = self._simulate_market_data(symbol)

    def _simulate_market_data(self, symbol):
        """Simulate realistic market data"""
        dates = pd.date_range(self.start_date, self.end_date, freq='1min')
        n_periods = len(dates)

        # Simulate price process (GBM)
        mu = 0.0001  # Drift
        sigma = 0.01  # Volatility
        price = 100.0
        prices = [price]

        for _ in range(n_periods - 1):
            shock = np.random.normal(mu, sigma)
            price *= (1 + shock)
            prices.append(price)

        # Create DataFrame
        df = pd.DataFrame({
            'timestamp': dates,
            'open': prices,
            'high': [p * (1 + abs(np.random.normal(0, 0.005))) for p in prices],
            'low': [p * (1 - abs(np.random.normal(0, 0.005))) for p in prices],
            'close': prices,
            'volume': np.random.lognormal(10, 1, n_periods)
        })

        # Add technical indicators
        df = self._add_technical_indicators(df)
        return df

    def _add_technical_indicators(self, df):
        """Add technical indicators to price data"""
        # Simple moving averages
        df['sma_20'] = df['close'].rolling(20).mean()
        df['sma_50'] = df['close'].rolling(50).mean()

        # RSI
        delta = df['close'].diff()
        gain = (delta.where(delta > 0, 0)).rolling(14).mean()
        loss = (-delta.where(delta < 0, 0)).rolling(14).mean()
        rs = gain / loss
        df['rsi'] = 100 - (100 / (1 + rs))

        # MACD
        ema_12 = df['close'].ewm(span=12).mean()
        ema_26 = df['close'].ewm(span=26).mean()
        df['macd'] = ema_12 - ema_26
        df['macd_signal'] = df['macd'].ewm(span=9).mean()

        # Bollinger Bands
        df['bb_middle'] = df['close'].rolling(20).mean()
        df['bb_std'] = df['close'].rolling(20).std()
        df['bb_upper'] = df['bb_middle'] + 2 * df['bb_std']
        df['bb_lower'] = df['bb_middle'] - 2 * df['bb_std']

        return df.dropna()

    def train_signal_models(self):
        """Train ML models for signal generation"""
        for symbol in self.symbols:
            df = self.data[symbol]

            # Prepare features and target
            features = ['sma_20', 'sma_50', 'rsi', 'macd', 'macd_signal',
                       'bb_middle', 'bb_upper', 'bb_lower']
            X = df[features]
            y = np.where(df['close'].shift(-1) > df['close'], 1, 0)  # 1 if price up tomorrow

            # Remove last row (no target)
            X = X[:-1]
            y = y[:-1]

            # Train simple model (in real implementation use more sophisticated models)
            from sklearn.ensemble import RandomForestClassifier
            model = RandomForestClassifier(n_estimators=100, random_state=42)
            model.fit(X, y)

            self.models[symbol] = model

    def generate_signals(self, current_data):
        """Generate trading signals"""
        signals = {}

        for symbol in self.symbols:
            if symbol in current_data:
                # Prepare features for prediction
                features = ['sma_20', 'sma_50', 'rsi', 'macd', 'macd_signal',
                           'bb_middle', 'bb_upper', 'bb_lower']
                X_pred = current_data[symbol][features].iloc[-1:].values

                # Get prediction
                model = self.models[symbol]
                prediction = model.predict_proba(X_pred)[0]

                # Generate signal
                if prediction[1] > 0.6:  # Strong buy signal
                    signals[symbol] = 'BUY'
                elif prediction[0] > 0.6:  # Strong sell signal
                    signals[symbol] = 'SELL'
                else:
                    signals[symbol] = 'HOLD'

        return signals

    def execute_trades(self, signals, capital_per_trade=10000):
        """Execute trades based on signals"""
        for symbol, signal in signals.items():
            current_price = self.data[symbol]['close'].iloc[-1]

            if signal == 'BUY' and symbol not in self.positions:
                # Buy logic
                shares = capital_per_trade / current_price
                self.positions[symbol] = {
                    'shares': shares,
                    'entry_price': current_price,
                    'entry_time': datetime.now()
                }
                print(f"BUY {shares:.2f} shares of {symbol} at ${current_price:.2f}")

            elif signal == 'SELL' and symbol in self.positions:
                # Sell logic
                position = self.positions[symbol]
                exit_price = current_price
                pnl = (exit_price - position['entry_price']) * position['shares']

                print(f"SELL {position['shares']:.2f} shares of {symbol} at ${exit_price:.2f}")
                print(f"P&L: ${pnl:.2f}")

                del self.positions[symbol]

    def run_trading_simulation(self):
        """Run complete trading simulation"""
        print("Starting quantitative trading simulation...")

        # Load historical data
        self.load_market_data()
        print(f"Loaded data for {len(self.symbols)} symbols")

        # Train models
        self.train_signal_models()
        print("Trained signal generation models")

        # Simulate trading (simplified)
        for i in range(100, len(self.data[self.symbols[0]]), 10):  # Every 10 periods
            current_data = {}
            for symbol in self.symbols:
                current_data[symbol] = self.data[symbol].iloc[:i+1]

            # Generate signals
            signals = self.generate_signals(current_data)

            # Execute trades
            self.execute_trades(signals)

        print("Trading simulation completed")
        print(f"Final positions: {list(self.positions.keys())}")

# Run simulation
pipeline = QuantitativeTradingPipeline(
    symbols=['AAPL', 'GOOGL', 'MSFT'],
    start_date='2023-01-01',
    end_date='2023-12-31'
)

pipeline.run_trading_simulation()
```

Questa implementazione fornisce una base solida per sistemi di trading quantitativo avanzati,
dimostrando come integrare machine learning, big data e risk management in un framework
coerente e scalabile.

Il futuro del trading quantitativo vedrà un'ulteriore integrazione di tecniche avanzate
come quantum computing per ottimizzazione, federated learning per privacy-preserving model
training, e sistemi di AI completamente autonomi per gestione del portafoglio.

