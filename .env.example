# Environment variables for pipeline ingestion
# Copy to .env and fill in actual values

# Input configuration
INPUT_DIR=./input

# Output configuration
OUTPUT_DIR=./output

# Configuration file path
INGEST_CONFIG=./config/ingest.yaml

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/ingest.log

# Temporary files (leave empty for system temp)
TEMP_ROOT_DIR=
